# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://getnavi.dev            # public site URL — used in emails + Stripe redirects
PORT=8000                              # backend HTTP port
PUBLIC_API_URL=https://api.getnavi.dev # public API/widget URL used in emails
# CORS — comma-separated origins allowed to call the API (the frontend domains).
ALLOWED_ORIGINS=https://getnavi.dev,https://www.getnavi.dev

# ── Admin ────────────────────────────────────────────────────────────────────
# Static bearer for /api/admin/* and the /admin React page (X-ADMIN-TOKEN).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=
ADMIN_EMAIL=                            # destination for runaway-cost + margin alerts

# ── Rate limiting (req/min) — tune at deploy if needed ────────────────────────
RATE_LIMIT_CHAT=30
RATE_LIMIT_TTS=60
RATE_LIMIT_WIDGET=120
RATE_LIMIT_ADMIN=30
PROVIDER_TIMEOUT_MS=8000

# ── Cost budgets — provider daily spend ceilings in EUR cents ────────────────
# When the last-24h provider cost exceeds this, an admin alert email is sent.
PROVIDER_BUDGET_DAILY_CENTS_ELEVENLABS=2000
PROVIDER_BUDGET_DAILY_CENTS_OPENAI=1500
PROVIDER_BUDGET_DAILY_CENTS_GROQ=500
PROVIDER_BUDGET_DAILY_CENTS_DEEPGRAM=500
QUOTA_WATCH_INTERVAL_MIN=60

# ── Backups (optional S3 push) ───────────────────────────────────────────────
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=7
AWS_S3_BACKUP_BUCKET=
AWS_S3_BACKUP_PREFIX=navi

# ── Uptime check ─────────────────────────────────────────────────────────────
API_URL=http://localhost:8000
UPTIME_TIMEOUT_MS=5000

# ── Database (Postgres) ───────────────────────────────────────────────────────
# Credentials for the `postgres` service in docker-compose.yml.
POSTGRES_USER=navi
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=navi
# Connection string used by the backend. Host = the `postgres` service name on
# the shared Docker network. The password MUST match POSTGRES_PASSWORD above.
# External/managed Postgres → use its host + set DATABASE_SSL=1.
DATABASE_URL=postgresql://navi:CHANGE_ME@postgres:5432/navi
DATABASE_SSL=0

# ── Stripe ───────────────────────────────────────────────────────────────────
# Run `node server/scripts/setup-stripe.js` to create products + fill the price IDs.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Subscription prices
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_AGENCY=price_...
# One-time session-pack prices (100 sessions)
STRIPE_PACK_STARTER=price_...
STRIPE_PACK_BUSINESS=price_...
STRIPE_PACK_AGENCY=price_...
# Set to 1 to enable Stripe Tax (IVA) + PDF invoicing
STRIPE_TAX_ENABLED=0

# ── LiveKit (voice) ───────────────────────────────────────────────────────────
LIVEKIT_API_KEY=APIxxxxxx
LIVEKIT_API_SECRET=your_secret_here
LIVEKIT_URL=wss://your-project.livekit.cloud      # used by agent worker + dispatch client
LIVEKIT_WS_URL=wss://your-project.livekit.cloud   # used by browser token route (same value)
LIVEKIT_WEBHOOK_SECRET=                           # = LIVEKIT_API_SECRET (LiveKit signs webhooks with it)

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...                   # widget chat + voice agent LLM
OPENAI_API_KEY=sk-...                  # KB embeddings (crawler) + TTS voices
OPENAI_TTS_MODEL=gpt-4o-mini-tts       # fallback TTS when ElevenLabs is not configured

# Premium TTS (recommended for realistic widget voice). When set, /api/tts uses
# ElevenLabs first and falls back to OpenAI only if ElevenLabs fails.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# ── Deepgram (STT for voice agent) ────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_key_here

# ── Fatture in Cloud (Italian SDI e-invoicing) ────────────────────────────────
# Optional. When set, paid invoices are forwarded to SDI. See server/fattureincloud.js
FIC_ACCESS_TOKEN=
FIC_COMPANY_ID=

# ── Frontend (Vite — must be prefixed VITE_) ──────────────────────────────────
# Build-time only — baked into dist/ by `npm run build`. Points at the API host.
VITE_BACKEND_URL=https://api.getnavi.dev
